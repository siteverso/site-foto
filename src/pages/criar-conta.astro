---
import AppLayout from '../layouts/AppLayout.astro';
import LanguageSwitch from '../components/LanguageSwitch.astro';
import { getMessages, normalizeLocale } from '../i18n';
import { currentUser } from '../lib/server/session';
if (await currentUser(Astro)) return Astro.redirect('/');

const locale = normalizeLocale(Astro.cookies.get('fotolife-language')?.value);
const t = getMessages(locale);
---
<AppLayout title={`${t.signup.title} — ${t.site.title}`} auth={false}>
  <main class="auth-page">
    <section class="auth-intro">
      <div class="auth-brand-row">
        <a class="brand" href="/login"><span class="brand-mark">f</span><span>{t.site.title}</span></a>
        <LanguageSwitch />
      </div>
      <div>
        <h1>{t.signup.headline}</h1>
        <p>{t.signup.intro}</p>
      </div>
      <small>{t.signup.description}</small>
    </section>
    <section class="auth-form-wrap">
      <form class="panel auth-card" data-signup-form>
        <h2>{t.signup.title}</h2>
        <p>{t.signup.description}</p>
        <div class="field">
          <label for="username">{t.common.username}</label>
          <input id="username" name="username" minlength="3" maxlength="30" autocomplete="username" required />
          <small>{t.signup.usernameHelp}</small>
        </div>
        <div class="field">
          <label for="email">{t.common.email}</label>
          <input id="email" name="email" type="email" autocomplete="email" required />
        </div>
        <div class="field">
          <label for="password">{t.common.password}</label>
          <input id="password" name="password" type="password" minlength="6" autocomplete="new-password" required />
        </div>
        <div class="field">
          <label for="confirmPassword">{t.common.confirmPassword}</label>
          <input id="confirmPassword" name="confirmPassword" type="password" minlength="6" autocomplete="new-password" required />
        </div>
        <button class="button primary full" type="submit">{t.signup.submit}</button>
        <p class="form-message" data-form-message></p>
        <div class="signup-callout"><span>{t.signup.haveAccount}</span><a href="/login">{t.signup.login}</a></div>
      </form>
    </section>
  </main>
  <div class="toast" data-toast></div>

  <script define:vars={{ signup: t.signup, genericError: t.errors.generic }}>
    const form = document.querySelector('[data-signup-form]');
    const message = form?.querySelector('[data-form-message]');
    const submit = form?.querySelector('button[type="submit"]');

    const showMessage = (text = '', type = 'error') => {
      if (!message) return;
      message.textContent = text;
      if (text) message.dataset.type = type;
      else delete message.dataset.type;
    };

    const errorMessages = {
      USUARIO_INVALIDO: signup.invalidUsername,
      EMAIL_INVALIDO: signup.invalidEmail,
      SENHA_INVALIDA: signup.invalidPassword,
      SENHAS_DIFERENTES: signup.passwordMismatch,
      CONTA_EXISTENTE: signup.existing,
    };

    form?.addEventListener('submit', async event => {
      event.preventDefault();
      if (!(form instanceof HTMLFormElement) || !(submit instanceof HTMLButtonElement)) return;

      const values = new FormData(form);
      const password = String(values.get('password') || '');
      const confirmPassword = String(values.get('confirmPassword') || '');

      if (password !== confirmPassword) {
        showMessage(signup.passwordMismatch);
        return;
      }

      submit.disabled = true;
      const originalLabel = submit.textContent;
      submit.textContent = signup.submitting;
      showMessage();

      try {
        const response = await fetch('/api/auth/signup', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          credentials: 'same-origin',
          body: JSON.stringify({
            username: values.get('username'),
            email: values.get('email'),
            password,
            confirmPassword,
          }),
        });
        const data = await response.json().catch(() => ({}));
        if (!response.ok) throw new Error(data?.error || 'ERRO_INTERNO');

        showMessage(signup.success, 'success');
        location.replace('/');
      } catch (error) {
        const code = error instanceof Error ? error.message : 'ERRO_INTERNO';
        showMessage(errorMessages[code] || genericError);
        submit.disabled = false;
        submit.textContent = originalLabel;
      }
    });
  </script>
</AppLayout>
