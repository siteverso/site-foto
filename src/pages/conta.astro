---
import AppLayout from '../layouts/AppLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import ProfileSidebar from '../components/ProfileSidebar.astro';
import { requireUser } from '../lib/server/session';
import { getMessages, normalizeLocale } from '../i18n';
import { MESSAGE_MAX_LENGTH } from '../lib/message-limit';
import { getAccountProfile } from '../lib/server/repositories/account-profile';
import { getPublicProfile } from '../lib/server/repositories/photos';
import { getProfilePrivacy, listBlockedUsers } from '../lib/server/repositories/profile-privacy';
import '../styles/pages/account.css';
import '../styles/themes/theme-overrides.css';
const user = await requireUser(Astro);
const account = await getAccountProfile(user.id);
const profilePrivacy = await getProfilePrivacy(user.id);
const blockedUsers = await listBlockedUsers(user.id);
// A lateral da conta usa a mesma origem de avatar já validada pela página pública do perfil.
const publicProfile = await getPublicProfile(account.username);
const accountSidebar = {
  ...account,
  id: user.id,
  avatarUrl: publicProfile?.avatarUrl || account.avatarUrl,
};
const locale = normalizeLocale(Astro.cookies.get('fotolife-language')?.value);
const t = getMessages(locale);
---
<AppLayout title={`${t.profile.title} — ${t.site.title}`}>
  <SiteHeader username={user.username} userId={user.id} avatarUrl={user.avatarUrl} />
  <main class="site-container site-section account-page">
    <header class="account-heading"><h1>{t.profile.title}</h1></header>
    <div class="profile-grid">
    <aside>
      <ProfileSidebar
        profile={accountSidebar}
        editableAvatar
        isOwner
        showStats
        labels={{ photos: t.profile.photos, messages: t.profile.messages, observed: t.profile.observed, observers: t.profile.observers }}
      />
    </aside>

    <div class="profile-sections">
      <section class="panel profile-edit">
        <h2>{t.profile.editTitle}</h2>
        <form data-profile-form data-page-managed>
          <div class="field"><label for="username">{t.common.username}</label><input id="username" name="username" maxlength="30" value={account.username} autocomplete="username" required /></div>
          <div class="field"><label for="email">{t.common.email}</label><input id="email" name="email" type="email" value={account.email} autocomplete="email" required /></div>
          <div class="field"><label for="bio">{t.profile.bio}</label><textarea id="bio" name="bio" maxlength={MESSAGE_MAX_LENGTH} rows="5">{account.bio}</textarea></div>
          <div class="field">
            <label for="sexCode">{t.profile.sex}</label>
            <select id="sexCode" name="sexCode">
              <option value="" selected={account.sexCode === ''}>{t.profile.sexUnknown}</option>
              <option value="M" selected={account.sexCode === 'M'}>{t.profile.sexMale}</option>
              <option value="F" selected={account.sexCode === 'F'}>{t.profile.sexFemale}</option>
            </select>
          </div>
          <div class="field">
            <label for="observerVisibility">{t.profile.observerVisibility}</label>
            <select id="observerVisibility" name="observerVisibility">
              <option value="public" selected={account.observerVisibility === 'public'}>{t.profile.observerVisibilityPublic}</option>
              <option value="private" selected={account.observerVisibility === 'private'}>{t.profile.observerVisibilityPrivate}</option>
            </select>
            <small class="field-help">{t.profile.observerVisibilityHelp}</small>
          </div>
          <fieldset class="field observed-privacy" data-observed-privacy data-empty-text={t.profile.hiddenObservedEmpty} hidden={account.observerVisibility === 'private'}>
            <legend>{t.profile.hiddenObservedTitle}</legend>
            <small class="field-help">{t.profile.hiddenObservedHelp}</small>
            <button class="observed-lov-trigger" type="button" data-observed-lov-open aria-haspopup="dialog">
              <span class="observed-lov-trigger-icon" aria-hidden="true">⌕</span>
              <span data-observed-lov-summary>{t.profile.hiddenObservedSearch}</span>
              <span class="observed-lov-trigger-count" data-observed-lov-count>0</span>
            </button>
            <div class="observed-lov-selection" data-observed-lov-selection></div>
            <div data-observed-hidden-inputs></div>
          </fieldset>
          <button class="button primary" type="submit">{t.common.save}</button>
          <p class="form-message" data-form-message hidden></p>
        </form>
      </section>


      <section class="panel profile-edit account-privacy-panel" data-profile-privacy-panel>
        <h2>Privacidade do perfil</h2>
        <p class="account-section-intro">Controle como seu perfil aparece sem alterar suas fotos ou seus dados.</p>
        <div class="profile-visibility-options" role="radiogroup" aria-label="Visibilidade do perfil">
          <label><input type="radio" name="profileVisibility" value="public" checked={profilePrivacy.visibility === 'public'} /><span><strong>Público</strong><small>Aparece normalmente no site e pode ser encontrado.</small></span></label>
          <label><input type="radio" name="profileVisibility" value="unlisted" checked={profilePrivacy.visibility === 'unlisted'} /><span><strong>Oculto</strong><small>Não aparece nas áreas de descoberta. Continua acessível pelo link direto.</small></span></label>
          <label><input type="radio" name="profileVisibility" value="private" checked={profilePrivacy.visibility === 'private'} /><span><strong>Bloqueado</strong><small>Somente você consegue entrar no perfil.</small></span></label>
        </div>
        <button class="button primary" type="button" data-save-profile-privacy>Salvar privacidade</button>
        <p class="form-message" data-privacy-message hidden></p>
      </section>

      <section class="panel profile-edit account-danger-zone">
        <div>
          <h2>Remover perfil</h2>
          <p>O perfil sai do site imediatamente, mas pode ser resgatado por você durante 30 dias.</p>
        </div>
        <button class="button account-remove-profile" type="button" data-remove-profile>Remover perfil</button>
      </section>

      <section class="panel profile-edit account-access">
        <h2>{t.profile.accountTitle}</h2>
        <p data-auth-explanation></p>
        <div class="auth-methods"><strong>{t.profile.accessMethods}</strong><span data-auth-methods></span></div>
        <form data-password-form data-page-managed>
          <h3 data-password-title>{t.profile.definePassword}</h3>
          <p>{t.profile.passwordHelp}</p>
          <div class="field"><label for="newPassword">{t.common.newPassword}</label><input id="newPassword" name="password" type="password" minlength="6" autocomplete="new-password" required /></div>
          <div class="field"><label for="confirmNewPassword">{t.common.confirmPassword}</label><input id="confirmNewPassword" name="confirmPassword" type="password" minlength="6" autocomplete="new-password" required /></div>
          <button class="button primary" type="submit">{t.profile.definePassword}</button>
          <p class="form-message" data-form-message hidden></p>
        </form>
      </section>

      <section class="panel profile-edit account-blocked-users" data-blocked-users-panel>
        <div class="account-blocked-users-heading">
          <div>
            <h2>Usuários bloqueados</h2>
            <p class="account-section-intro">Gerencie perfis e mensagens que você bloqueou.</p>
          </div>
          <span class="account-blocked-users-count" data-blocked-users-count>{blockedUsers.length}</span>
        </div>
        <div class="account-blocked-users-list" data-blocked-users-list>
          {blockedUsers.map(blocked => (
            <article class="account-blocked-user" data-blocked-user data-user-id={blocked.id} data-level={blocked.level}>
              <img src={blocked.avatarUrl} alt="" loading="lazy" />
              <div class="account-blocked-user-identity">
                <strong>@{blocked.username}</strong>
                <div class="account-blocked-user-badges">
                  {blocked.blocksProfile && <span title="Perfil bloqueado">⊘ Perfil</span>}
                  {blocked.blocksMessages && <span title="Mensagens bloqueadas">✉ Mensagens</span>}
                </div>
              </div>
              <button class="button account-unblock-user" type="button" data-unblock-user data-user-id={blocked.id} data-level={blocked.level}>
                {blocked.level === 'all' ? 'Desbloquear perfil' : 'Permitir mensagens'}
              </button>
            </article>
          ))}
          <p class="account-blocked-users-empty" data-blocked-users-empty hidden={blockedUsers.length > 0}>Você não bloqueou nenhum usuário.</p>
        </div>
        <p class="form-message" data-blocked-users-message hidden></p>
      </section>
    </div>
    </div>
  </main>
  <div class="observed-lov-backdrop" data-observed-lov hidden>
    <section class="observed-lov-dialog" role="dialog" aria-modal="true" aria-labelledby="observed-lov-title">
      <header class="observed-lov-header">
        <div>
          <h2 id="observed-lov-title">{t.profile.hiddenObservedDialogTitle}</h2>
          <p>{t.profile.hiddenObservedDialogHelp}</p>
        </div>
        <button class="observed-lov-close" type="button" data-observed-lov-close aria-label={t.common.close}>×</button>
      </header>
      <label class="observed-lov-search">
        <span aria-hidden="true">⌕</span>
        <input type="search" data-observed-lov-search placeholder={t.profile.hiddenObservedSearch} autocomplete="off" />
      </label>
      <div class="observed-lov-results" data-observed-lov-results></div>
      <footer class="observed-lov-actions">
        <button class="button" type="button" data-observed-lov-cancel>{t.common.cancel}</button>
        <button class="button primary" type="button" data-observed-lov-apply>{t.common.apply}</button>
      </footer>
    </section>
  </div>
  <div class="toast" data-toast></div>
</AppLayout>


<script define:vars={{ clientMessages: {
    accountExists: t.errors.accountExists, invalidUsername: t.signup.invalidUsername, invalidEmail: t.signup.invalidEmail, invalidSex: t.errors.invalidSex, invalidPassword: t.signup.invalidPassword, passwordMismatch: t.signup.passwordMismatch, sessionExpired: t.errors.sessionExpired, generic: t.errors.generic, noBio: t.common.noBio, emptyObserved: t.profile.hiddenObservedEmpty, password: t.common.password, google: "Google", none: t.common.none, changePassword: t.common.changePassword, definePassword: t.common.definePassword, saving: t.common.saving, googleAccess: t.profile.googleAccess, passwordAccess: t.profile.passwordAccess, accountUpdated: t.profile.accountUpdated, passwordUpdated: t.profile.passwordUpdated, searchObserved: t.profile.hiddenObservedSearch, noObservedResults: t.profile.hiddenObservedNoResults
  } }}>
  const profileForm = document.querySelector('[data-profile-form]');
  const passwordForm = document.querySelector('[data-password-form]');
  const toastElement = document.querySelector('[data-toast]');
  const observedPrivacy = document.querySelector('[data-observed-privacy]');
  const observedLov = document.querySelector('[data-observed-lov]');
  const observedLovOpen = document.querySelector('[data-observed-lov-open]');
  const observedLovSearch = document.querySelector('[data-observed-lov-search]');
  const observedLovResults = document.querySelector('[data-observed-lov-results]');
  const observedLovSelection = document.querySelector('[data-observed-lov-selection]');
  const observedLovSummary = document.querySelector('[data-observed-lov-summary]');
  const observedLovCount = document.querySelector('[data-observed-lov-count]');
  const observedHiddenInputs = document.querySelector('[data-observed-hidden-inputs]');
  let observedUsers = [];
  let selectedObservedIds = new Set();
  let draftObservedIds = new Set();

  const api = async (url, options = {}) => {
    const response = await fetch(url, {
      cache: 'no-store',
      ...options,
      headers: { 'Content-Type': 'application/json', ...(options.headers || {}) },
    });
    const data = await response.json().catch(() => ({}));
    if (!response.ok) throw new Error(data.error || 'ERRO_INTERNO');
    return data;
  };

  const messages = { CONTA_EXISTENTE: clientMessages.accountExists, USUARIO_INVALIDO: clientMessages.invalidUsername, EMAIL_INVALIDO: clientMessages.invalidEmail, SEXO_INVALIDO: clientMessages.invalidSex, SENHA_INVALIDA: clientMessages.invalidPassword, SENHAS_DIFERENTES: clientMessages.passwordMismatch, NAO_AUTENTICADO: clientMessages.sessionExpired, ERRO_INTERNO: clientMessages.generic };

  function showMessage(form, text = '', type = 'info') {
    const element = form?.querySelector('[data-form-message]');
    if (!element) return;
    element.textContent = text;
    element.dataset.type = type;
    element.hidden = !text;
  }

  function setLoading(button, loading, loadingText) {
    if (!button) return;
    if (loading) {
      button.dataset.label = button.textContent.trim();
      button.disabled = true;
      button.textContent = loadingText;
    } else {
      button.disabled = false;
      button.textContent = button.dataset.label || button.textContent;
      delete button.dataset.label;
    }
  }

  function toast(text) {
    if (!toastElement) return;
    toastElement.textContent = text;
    toastElement.classList.add('show');
    window.clearTimeout(toastElement._timer);
    toastElement._timer = window.setTimeout(() => toastElement.classList.remove('show'), 3000);
  }

  function initials(username = '') {
    return String(username).trim().slice(0, 2).toUpperCase() || 'FL';
  }

  function normalizedSearch(value = '') {
    return String(value).trim().toLocaleLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
  }

  function renderObservedSelection() {
    if (!observedLovSelection || !observedHiddenInputs) return;
    observedLovSelection.replaceChildren();
    observedHiddenInputs.replaceChildren();
    const selected = observedUsers.filter(item => selectedObservedIds.has(Number(item.id)));
    selected.forEach(item => {
      const chip = document.createElement('button');
      chip.type = 'button';
      chip.className = 'observed-lov-chip';
      chip.textContent = `@${item.username} ×`;
      chip.addEventListener('click', () => {
        selectedObservedIds.delete(Number(item.id));
        renderObservedSelection();
      });
      observedLovSelection.append(chip);

      const input = document.createElement('input');
      input.type = 'hidden';
      input.name = 'hiddenObservedUserIds';
      input.value = String(item.id);
      observedHiddenInputs.append(input);
    });
    const count = selected.length;
    observedLovCount.textContent = String(count);
    observedLovSummary.textContent = count ? `${count} pessoa${count === 1 ? '' : 's'} oculta${count === 1 ? '' : 's'}` : clientMessages.searchObserved;
  }

  function renderObservedResults() {
    if (!observedLovResults) return;
    const query = normalizedSearch(observedLovSearch?.value);
    const filtered = observedUsers.filter(item => normalizedSearch(`${item.displayName || ''} ${item.username || ''}`).includes(query));
    observedLovResults.replaceChildren();
    if (filtered.length === 0) {
      const empty = document.createElement('p');
      empty.className = 'observed-privacy-empty';
      empty.textContent = observedUsers.length ? clientMessages.noObservedResults : clientMessages.emptyObserved;
      observedLovResults.append(empty);
      return;
    }
    filtered.forEach(item => {
      const label = document.createElement('label');
      label.className = 'observed-lov-result';
      const checkbox = document.createElement('input');
      checkbox.type = 'checkbox';
      checkbox.checked = draftObservedIds.has(Number(item.id));
      checkbox.addEventListener('change', () => {
        if (checkbox.checked) draftObservedIds.add(Number(item.id));
        else draftObservedIds.delete(Number(item.id));
      });
      const avatar = document.createElement('span');
      avatar.className = 'observed-privacy-avatar';
      avatar.textContent = initials(item.username);
      const identity = document.createElement('span');
      identity.className = 'observed-lov-identity';
      const name = document.createElement('strong');
      name.textContent = item.displayName || `@${item.username}`;
      const username = document.createElement('small');
      username.textContent = `@${item.username}`;
      identity.append(name, username);
      label.append(checkbox, avatar, identity);
      observedLovResults.append(label);
    });
  }

  function syncObservedPrivacyState() {
    const isPublic = profileForm?.observerVisibility?.value === 'public';
    if (!observedPrivacy || !observedLovOpen) return;
    observedPrivacy.hidden = !isPublic;
    observedPrivacy.disabled = !isPublic;
    observedLovOpen.disabled = !isPublic || observedUsers.length === 0;
    if (!isPublic && observedLov && !observedLov.hidden) closeObservedLov();
  }

  function openObservedLov() {
    if (!observedLov || observedLovOpen.disabled) return;
    draftObservedIds = new Set(selectedObservedIds);
    observedLovSearch.value = '';
    renderObservedResults();
    observedLov.hidden = false;
    document.body.classList.add('modal-open');
    requestAnimationFrame(() => observedLovSearch.focus());
  }

  function closeObservedLov() {
    if (!observedLov) return;
    observedLov.hidden = true;
    document.body.classList.remove('modal-open');
    observedLovOpen?.focus();
  }

  function renderAccount(account) {
    document.querySelectorAll('[data-user-name]').forEach(element => {
      element.textContent = `@${account.username}`;
    });
    document.querySelectorAll('[data-user-profile-link]').forEach(element => {
      element.href = `/perfil/${encodeURIComponent(account.username)}`;
    });
    const avatarFallback = document.querySelector('[data-profile-avatar-fallback]');
    if (avatarFallback) avatarFallback.textContent = initials(account.username);
    const profileUsername = document.querySelector('[data-profile-username]');
    if (profileUsername) profileUsername.textContent = `@${account.username}`;
    const profileEmail = document.querySelector('[data-profile-email]');
    if (profileEmail) profileEmail.textContent = account.email;
    const profileBio = document.querySelector('[data-profile-bio]');
    if (profileBio) profileBio.textContent = account.bio || clientMessages.noBio;
    const profilePosts = document.querySelector('[data-profile-posts]');
    if (profilePosts) profilePosts.textContent = account.photoCount;
    const profileMessages = document.querySelector('[data-profile-positive]');
    if (profileMessages) profileMessages.textContent = account.messageCount;
    const profileObserved = document.querySelector('[data-profile-observed]');
    if (profileObserved) profileObserved.textContent = account.observedCount;
    const profileObservers = document.querySelector('[data-profile-shares]');
    if (profileObservers) profileObservers.textContent = account.observerCount;

    profileForm.username.value = account.username;
    profileForm.email.value = account.email;
    profileForm.bio.value = account.bio || '';
    profileForm.sexCode.value = account.sexCode || '';
    profileForm.observerVisibility.value = account.observerVisibility || 'public';
    observedUsers = Array.isArray(account.observedUsers) ? account.observedUsers : [];
    selectedObservedIds = new Set(observedUsers.filter(item => item.hidden).map(item => Number(item.id)));
    renderObservedSelection();
    syncObservedPrivacyState();

    const methods = [];
    if (account.hasPassword) methods.push(clientMessages.password);
    if (account.hasGoogle) methods.push(clientMessages.google);
    document.querySelector('[data-auth-methods]').textContent = methods.join(' + ') || clientMessages.none;
    document.querySelector('[data-auth-explanation]').textContent = account.hasGoogle
      ? clientMessages.googleAccess
      : clientMessages.passwordAccess;

    const passwordLabel = account.hasPassword ? clientMessages.changePassword : clientMessages.definePassword;
    document.querySelector('[data-password-title]').textContent = passwordLabel;
    passwordForm.querySelector('button[type="submit"]').textContent = passwordLabel;
  }

  async function loadAccount() {
    try {
      const data = await api('/api/auth/profile');
      renderAccount(data.account);
    } catch (error) {
      if (error.message === 'NAO_AUTENTICADO') location.replace('/login');
      else showMessage(profileForm, messages[error.message] || messages.ERRO_INTERNO, 'error');
    }
  }

  profileForm?.observerVisibility?.addEventListener('change', syncObservedPrivacyState);
  observedLovOpen?.addEventListener('click', openObservedLov);
  observedLovSearch?.addEventListener('input', renderObservedResults);
  document.querySelector('[data-observed-lov-close]')?.addEventListener('click', closeObservedLov);
  document.querySelector('[data-observed-lov-cancel]')?.addEventListener('click', closeObservedLov);
  document.querySelector('[data-observed-lov-apply]')?.addEventListener('click', () => {
    selectedObservedIds = new Set(draftObservedIds);
    renderObservedSelection();
    closeObservedLov();
  });
  observedLov?.addEventListener('click', event => {
    if (event.target === observedLov) closeObservedLov();
  });
  document.addEventListener('keydown', event => {
    if (event.key === 'Escape' && observedLov && !observedLov.hidden) closeObservedLov();
  });

  profileForm?.addEventListener('submit', async event => {
    event.preventDefault();
    const button = profileForm.querySelector('button[type="submit"]');
    showMessage(profileForm);
    setLoading(button, true, 'Salvando…');
    try {
      const data = await api('/api/auth/profile', {
        method: 'PATCH',
        body: JSON.stringify({
          username: profileForm.username.value,
          email: profileForm.email.value,
          bio: profileForm.bio.value,
          sexCode: profileForm.sexCode.value,
          observerVisibility: profileForm.observerVisibility.value,
          hiddenObservedUserIds: [...selectedObservedIds],
        }),
      });
      renderAccount(data.account);
      showMessage(profileForm, 'Dados da conta salvos com sucesso.', 'success');
      toast(clientMessages.accountUpdated);
    } catch (error) {
      showMessage(profileForm, messages[error.message] || messages.ERRO_INTERNO, 'error');
    } finally {
      setLoading(button, false);
    }
  });

  passwordForm?.addEventListener('submit', async event => {
    event.preventDefault();
    const button = passwordForm.querySelector('button[type="submit"]');
    showMessage(passwordForm);
    setLoading(button, true, 'Atualizando…');
    try {
      await api('/api/auth/password', {
        method: 'PATCH',
        body: JSON.stringify({
          password: passwordForm.password.value,
          confirmPassword: passwordForm.confirmPassword.value,
        }),
      });
      passwordForm.reset();
      await loadAccount();
      showMessage(passwordForm, 'Senha atualizada com sucesso.', 'success');
      toast(clientMessages.passwordUpdated);
    } catch (error) {
      showMessage(passwordForm, messages[error.message] || messages.ERRO_INTERNO, 'error');
    } finally {
      setLoading(button, false);
    }
  });

  loadAccount();

  const privacyMessage = document.querySelector('[data-privacy-message]');
  document.querySelector('[data-save-profile-privacy]')?.addEventListener('click', async (event) => {
    const button = event.currentTarget;
    const visibility = document.querySelector('input[name="profileVisibility"]:checked')?.value || 'public';
    button.disabled = true;
    try {
      await api('/api/profile/privacy', { method: 'PATCH', body: JSON.stringify({ visibility }) });
      privacyMessage.textContent = 'Privacidade atualizada.'; privacyMessage.dataset.type = 'success'; privacyMessage.hidden = false;
    } catch (error) {
      privacyMessage.textContent = messages[error.message] || clientMessages.generic; privacyMessage.dataset.type = 'error'; privacyMessage.hidden = false;
    } finally { button.disabled = false; }
  });

  const blockedUsersList = document.querySelector('[data-blocked-users-list]');
  const blockedUsersCount = document.querySelector('[data-blocked-users-count]');
  const blockedUsersEmpty = document.querySelector('[data-blocked-users-empty]');
  const blockedUsersMessage = document.querySelector('[data-blocked-users-message]');

  blockedUsersList?.addEventListener('click', async event => {
    const button = event.target.closest('[data-unblock-user]');
    if (!button) return;
    const userId = Number(button.dataset.userId);
    const level = button.dataset.level === 'messages' ? 'messages' : 'all';
    button.disabled = true;
    blockedUsersMessage.hidden = true;
    try {
      await api('/api/profile/block', {
        method: 'PATCH',
        body: JSON.stringify({ userId, level, blocked: false }),
      });
      button.closest('[data-blocked-user]')?.remove();
      const remaining = blockedUsersList.querySelectorAll('[data-blocked-user]').length;
      blockedUsersCount.textContent = String(remaining);
      blockedUsersEmpty.hidden = remaining > 0;
      toast(level === 'all' ? 'Perfil desbloqueado.' : 'Mensagens liberadas.');
    } catch (error) {
      blockedUsersMessage.textContent = messages[error.message] || clientMessages.generic;
      blockedUsersMessage.dataset.type = 'error';
      blockedUsersMessage.hidden = false;
      button.disabled = false;
    }
  });

  document.querySelector('[data-remove-profile]')?.addEventListener('click', async (event) => {
    if (!confirm('Remover seu perfil do site? Você terá 30 dias para resgatá-lo ao entrar novamente.')) return;
    const button = event.currentTarget; button.disabled = true;
    try {
      await api('/api/profile/privacy', { method: 'PATCH', body: JSON.stringify({ action: 'remove' }) });
      location.href = '/login?perfil=removido';
    } catch (error) { button.disabled = false; toast(clientMessages.generic); }
  });
</script>
