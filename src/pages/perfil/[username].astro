---
import '../../styles/pages/profile-detail.css';
import AppLayout from '../../layouts/AppLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import ProfileSidebar from '../../components/ProfileSidebar.astro';
import { requireUser } from '../../lib/server/session';
import { getComments, getLatestPhotos, getObservedPhotos, getObserverPhotos, getPublicProfile, getUserPhotos, isFriend } from '../../lib/server/repositories/photos';
import { getMessages, normalizeLocale } from '../../i18n';
import { MESSAGE_MAX_LENGTH } from '../../lib/message-limit';
import { canViewObservedList } from '../../lib/observer-visibility';
import { getObservedSectionTitle, getObserverSectionTitle } from '../../lib/profile-observer-copy';

const user = await requireUser(Astro);
const locale = normalizeLocale(Astro.cookies.get('fotolife-language')?.value);
const t = getMessages(locale);
const username = String(Astro.params.username || '').trim();
const profile = username ? await getPublicProfile(username) : null;
if (!profile) Astro.response.status = 404;
const isOwner = Boolean(profile && profile.id === user.id);
const photos = profile ? await getUserPhotos(profile.username) : [];
const alreadyFriend = profile && !isOwner ? await isFriend(user.id, profile.id) : false;
const showObservedList = Boolean(profile && canViewObservedList(profile.id, user.id, profile.observerVisibility));
const [observerPhotos, observedPhotos, latestPhotos, commentsByPhoto] = await Promise.all([
  profile ? getObserverPhotos(profile.id) : Promise.resolve([]),
  profile && showObservedList ? getObservedPhotos(profile.id, isOwner) : Promise.resolve([]),
  profile ? getLatestPhotos(profile.id) : Promise.resolve([]),
  Promise.all(photos.map(async photo => ({ photoId: photo.id, comments: await getComments(photo.id, user.id, 50) }))),
]);
const commentsMap = new Map(commentsByPhoto.map(item => [item.photoId, item.comments]));
const observedSectionTitle = profile ? getObservedSectionTitle(isOwner, profile.sexCode) : 'Observando';
const observerSectionTitle = profile ? getObserverSectionTitle(isOwner, profile.sexCode) : 'Observadores';
const formatDate = (value: string) => new Intl.DateTimeFormat(locale, { day: '2-digit', month: 'short', year: 'numeric' }).format(new Date(value));
---
<AppLayout title={profile ? `@${profile.username} — ${t.site.title}` : t.publicProfile.notFound}>
  <main class="flog-page">
    <SiteHeader username={user.username} />

    {profile ? (
      <section class="flog-grid">
        <aside class="flog-panel">
          <ProfileSidebar
            profile={profile}
            isOwner={isOwner}
            alreadyFriend={alreadyFriend}
            labels={{ addFriend: t.publicProfile.addFriend, alreadyFriend: t.publicProfile.alreadyFriend }}
          />

          <section class="profile-side-section" data-profile-observed data-empty-message={`@${profile.username} ainda não observa nenhum perfil.`}>
            <h2>{observedSectionTitle}</h2>
            {showObservedList ? (
              observedPhotos.length ? (
                <div class="photo-mini-grid" data-live-section="profile-observed" data-live-list>{observedPhotos.map(item => (
                  <article class="photo-mini-card" data-live-key={`observed-${item.userId}`} data-observed-user-id={item.userId}>
                    {isOwner && (
                      <button
                        class="photo-mini-remove"
                        type="button"
                        data-remove-friend
                        data-user-id={item.userId}
                        aria-label={`Deixar de observar @${item.username}`}
                        title={`Deixar de observar @${item.username}`}
                      >×</button>
                    )}
                    <a class="photo-mini-image" href={`/perfil/${item.username}`}><img src={`/api/photos/${item.id}`} alt={item.caption || item.username} loading="lazy" /></a>
                    <div><a href={`/perfil/${item.username}`}><strong>@{item.username}</strong></a><time>{formatDate(item.publishedAt)}</time></div>
                  </article>
                ))}</div>
              ) : <p class="empty-state">@{profile.username} ainda não observa nenhum perfil.</p>
            ) : <p class="empty-state">Esta lista é privada.</p>}
          </section>
        </aside>

        <section class="flog-center">
          {isOwner && (
            <button class="profile-new-post-button" type="button" data-open-post-dialog>
              <span aria-hidden="true">＋</span>
              <strong>Nova postagem</strong>
            </button>
          )}

          <div class="profile-photo-feed" data-live-section="profile-feed" data-live-list>
          {photos.length ? (
              photos.map(photo => {
                const comments = commentsMap.get(photo.id);
                return (
                  <article class="profile-photo-post" data-live-key={`photo-${photo.id}`}>
                    <div class="daily-photo" data-daily-photo>
                      {isOwner && (
                        <div class="daily-photo-actions">
                          <button class="daily-photo-edit" type="button" data-edit-caption aria-label="Editar legenda" title="Editar legenda">
                            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 16.5V20h3.5L18 9.5 14.5 6 4 16.5Zm16.7-9.8a1 1 0 0 0 0-1.4l-2-2a1 1 0 0 0-1.4 0l-1.6 1.6 3.5 3.5 1.5-1.7Z" /></svg>
                          </button>
                          <button class="daily-photo-delete" type="button" data-delete-photo data-photo-id={photo.id} aria-label={t.home.deletePhoto} title={t.home.deletePhoto}>×</button>
                        </div>
                      )}
                      <img src={`/api/photos/${photo.id}`} alt={photo.caption || t.home.today} loading="lazy" />
                      <p data-photo-caption data-editable-caption={isOwner ? "true" : undefined} title={isOwner ? "Duplo clique para editar a legenda" : undefined} hidden={!photo.caption}>{photo.caption}</p>
                      {isOwner && (
                        <form class="photo-caption-form" data-caption-form data-photo-id={photo.id} hidden>
                          <textarea name="caption" maxlength={MESSAGE_MAX_LENGTH} aria-label="Legenda da foto">{photo.caption}</textarea>
                          <div>
                            <button type="button" data-cancel-caption>Cancelar</button>
                            <button type="submit">Salvar</button>
                          </div>
                          <p data-caption-message hidden></p>
                        </form>
                      )}
                    </div>

                    <section class="comments-panel" data-comments-panel>
                      <h2>{t.home.comments}</h2>
                      <div class="comment-list" data-comment-list hidden={!comments?.items.length}>{comments?.items.map(comment => (
                        <article class:list={[
                          "comment-item",
                          {
                            "comment-item-private-visible": comment.isPrivate && comment.canRead,
                            "comment-item-private-hidden": comment.isPrivate && !comment.canRead,
                          },
                        ]} data-comment-item data-comment-id={comment.id}>
                          <div class="comment-content">
                            <a class="comment-user" href={`/perfil/${comment.username}`}><strong>@{comment.username}</strong></a>
                            {comment.isPrivate && !comment.canRead
                              ? <p class="private-comment-placeholder private-comment-placeholder-hidden"><span aria-hidden="true">🔒</span> Mensagem privada</p>
                              : <>
                                  {comment.isPrivate && <div class="private-comment-badge private-comment-badge-visible"><span aria-hidden="true">🔒</span> Mensagem privada</div>}
                                  <p class:list={[{ "private-comment-message": comment.isPrivate }]}>{comment.message}</p>
                                </>}
                            <div class="comment-meta">
                              {(comment.userId === user.id || isOwner) && (
                                <div class="comment-delete-area" data-comment-delete-area>
                                  <button class="comment-delete-trigger" type="button" data-comment-delete-trigger aria-label="Excluir mensagem" title="Excluir mensagem">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 7h16M9 7V4h6v3m-8 0 1 13h8l1-13M10 11v5m4-5v5" /></svg>
                                  </button>
                                </div>
                              )}
                              <time>{formatDate(comment.createdAt)}</time>
                            </div>
                          </div>
                        </article>
                      ))}</div>
                      <p class="empty-state comment-empty" data-comment-empty hidden={Boolean(comments?.items.length)}>{t.home.noComments}</p>
                      <form class="comment-form comment-form-unified" data-comment-form data-post-id={photo.id}>
                        <input name="message" maxlength={MESSAGE_MAX_LENGTH} placeholder={t.home.commentPlaceholder} autocomplete="off" required />
                        {!isOwner && (
                          <label class="private-toggle" title={`Somente @${profile.username} poderá ler`}>
                            <input type="checkbox" name="private" />
                            <span><i aria-hidden="true"></i><b class="private-toggle-public">Público</b><b class="private-toggle-private">Privado</b></span>
                          </label>
                        )}
                        <button type="submit" aria-label={t.home.send} title={t.home.send}>
                          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 12 20 4l-5.5 16-3.1-6.4L4 12Zm7.4 1.6L20 4" /></svg>
                        </button>
                      </form>
                      <p class="comment-form-message" data-comment-message hidden></p>
                    </section>
                  </article>
                );
              })
          ) : <p class="empty-state profile-no-photo" data-live-key="empty">{isOwner ? t.home.noPhoto : t.publicProfile.noPhotos}</p>}
          </div>
        </section>

        <aside class="flog-panel">
          <section class="profile-side-section">
            <h2>{observerSectionTitle}</h2>
            {observerPhotos.length ? (
              <div class="photo-mini-grid" data-live-section="profile-observers" data-live-list>{observerPhotos.map(item => (
                <article class="photo-mini-card" data-live-key={`observer-${item.userId}`}>
                  <a class="photo-mini-image" href={`/perfil/${item.username}`}><img src={`/api/photos/${item.id}`} alt={item.caption || item.username} loading="lazy" /></a>
                  <div><a href={`/perfil/${item.username}`}><strong>@{item.username}</strong></a><time>{formatDate(item.publishedAt)}</time></div>
                </article>
              ))}</div>
            ) : <p class="empty-state">Ainda não há observadores.</p>}
          </section>

          <section class="profile-side-section profile-updates-section">
            <h2>{t.home.updates}</h2>
            {latestPhotos.length ? <div class="photo-mini-grid" data-live-section="profile-updates" data-live-list>{latestPhotos.map(item => (
              <article class="photo-mini-card" data-live-key={`update-${item.id}`}><a class="photo-mini-image" href={`/perfil/${item.username}`}><img src={`/api/photos/${item.id}`} alt={item.caption || item.username} loading="lazy" /></a><div><a href={`/perfil/${item.username}`}><strong>@{item.username}</strong></a><time>{formatDate(item.publishedAt)}</time></div></article>
            ))}</div> : <p class="empty-state">{t.home.noUpdates}</p>}
          </section>
        </aside>
      </section>
    ) : <section class="public-profile-not-found"><h1>{t.publicProfile.notFound}</h1><a href="/">{t.publicProfile.back}</a></section>}
  </main>

  {profile && (
    <div class="profile-avatar-dialog" data-avatar-dialog hidden>
      <button class="profile-avatar-dialog-backdrop" type="button" data-close-avatar-dialog aria-label="Fechar foto de perfil"></button>
      <section class="profile-avatar-dialog-card" role="dialog" aria-modal="true" aria-label={`Foto de perfil de @${profile.username}`}>
        <button class="profile-avatar-dialog-close" type="button" data-close-avatar-dialog aria-label="Fechar">×</button>
        <div class="profile-avatar-dialog-image">
          {profile.avatarUrl ? <img src={profile.avatarUrl} alt={`@${profile.username}`} /> : <span>{profile.username.slice(0,2).toUpperCase()}</span>}
        </div>
      </section>
    </div>
  )}

  {isOwner && (
    <div class="post-dialog" data-post-dialog hidden>
      <div class="post-dialog-backdrop" data-close-post-dialog></div>
      <section class="post-dialog-card" role="dialog" aria-modal="true" aria-label="Nova postagem">
        <header>
          <h2>Nova postagem</h2>
          <button type="button" aria-label="Fechar" data-close-post-dialog>×</button>
        </header>
        <form class="daily-upload post-dialog-form" data-photo-form data-processing-text={t.home.processing}>
          <label class="upload-drop" data-upload-drop>
            <input name="photo" type="file" accept="image/*" required data-photo-input />
            <img class="upload-preview" alt="" data-photo-preview hidden />
            <span data-photo-label>{t.home.choosePhoto}</span>
          </label>
          <div class="photo-upload-progress" data-upload-progress hidden>
            <div class="photo-upload-progress-head">
              <span data-upload-status>{t.home.uploading}</span>
              <strong data-upload-percent>0%</strong>
            </div>
            <div class="photo-upload-progress-track" data-upload-bar><span data-upload-fill></span></div>
          </div>
          <textarea name="caption" maxlength={MESSAGE_MAX_LENGTH} placeholder={t.home.caption}></textarea>
          <p class="form-message post-dialog-message" data-post-message hidden></p>
          <button type="submit" data-publish-button disabled>{t.home.publish}</button>
        </form>
      </section>
    </div>
  )}

  <script>
    const avatarDialog = document.querySelector<HTMLElement>('[data-avatar-dialog]');
    const setAvatarDialogOpen = (open: boolean) => {
      if (!avatarDialog) return;
      avatarDialog.hidden = !open;
      document.documentElement.classList.toggle('has-open-dialog', open);
      if (open) avatarDialog.querySelector<HTMLButtonElement>('[data-close-avatar-dialog]')?.focus();
    };

    document.querySelector<HTMLButtonElement>('[data-open-avatar-dialog]')?.addEventListener('click', () => setAvatarDialogOpen(true));
    document.querySelectorAll<HTMLButtonElement>('[data-close-avatar-dialog]').forEach(button => {
      button.addEventListener('click', () => setAvatarDialogOpen(false));
    });
    document.addEventListener('keydown', event => {
      if (event.key === 'Escape' && avatarDialog && !avatarDialog.hidden) setAvatarDialogOpen(false);
    });

    document.querySelector<HTMLButtonElement>('[data-friend-toggle]')?.addEventListener('click', async event => {
      const button = event.currentTarget;
      const userId = button.dataset.userId;
      if (!userId || button.disabled) return;

      button.disabled = true;
      const method = button.dataset.observing === 'true' ? 'DELETE' : 'POST';
      const response = await fetch(`/api/friends/${userId}`, { method });
      if (response.ok) location.reload();
      else {
        button.disabled = false;
        alert(await response.text());
      }
    });
    document.addEventListener('click', async event => {
      const removeFriendButton = (event.target as HTMLElement).closest<HTMLButtonElement>('[data-remove-friend]');
      if (removeFriendButton) {
        const userId = removeFriendButton.dataset.userId;
        if (!userId || removeFriendButton.disabled) return;
        removeFriendButton.disabled = true;
        const response = await fetch(`/api/friends/${userId}`, { method: 'DELETE' });
        if (!response.ok) {
          removeFriendButton.disabled = false;
          alert(await response.text());
          return;
        }
        document.querySelectorAll<HTMLElement>(`[data-observed-user-id="${CSS.escape(userId)}"]`).forEach(card => card.remove());
        const section = document.querySelector<HTMLElement>('[data-profile-observed]');
        const grid = section?.querySelector('[data-live-list]');
        if (section && grid && !grid.querySelector('[data-observed-user-id]')) {
          grid.remove();
          const empty = document.createElement('p');
          empty.className = 'empty-state';
          empty.textContent = section.dataset.emptyMessage || 'Este usuário ainda não observa nenhum perfil.';
          section.append(empty);
        }
        return;
      }

      const editCaptionButton = (event.target as HTMLElement).closest<HTMLButtonElement>('[data-edit-caption]');
      if (editCaptionButton) {
        openCaptionEditor(editCaptionButton.closest<HTMLElement>('[data-daily-photo]'));
        return;
      }

      const cancelCaptionButton = (event.target as HTMLElement).closest<HTMLButtonElement>('[data-cancel-caption]');
      if (cancelCaptionButton) {
        const form = cancelCaptionButton.closest<HTMLFormElement>('[data-caption-form]');
        const caption = form?.closest<HTMLElement>('[data-daily-photo]')?.querySelector<HTMLElement>('[data-photo-caption]');
        const textarea = form?.querySelector<HTMLTextAreaElement>('textarea');
        if (textarea) textarea.value = caption?.textContent || '';
        if (form) form.hidden = true;
        return;
      }

      const current = (event.target as HTMLElement).closest<HTMLButtonElement>('[data-delete-photo]');
      if (!current) return;
      if (!confirm(current.title)) return;
      const response = await fetch(`/api/photos/${current.dataset.photoId}`, { method: 'DELETE' });
      if (!response.ok) alert(await response.text());
    });
    const openCaptionEditor = (photo: HTMLElement | null) => {
      const form = photo?.querySelector<HTMLFormElement>('[data-caption-form]');
      if (!form) return;
      form.hidden = false;
      const textarea = form.querySelector<HTMLTextAreaElement>('textarea');
      textarea?.focus();
      textarea?.setSelectionRange(textarea.value.length, textarea.value.length);
    };

    document.querySelectorAll<HTMLElement>('[data-editable-caption="true"]').forEach(caption => {
      caption.addEventListener('dblclick', () => openCaptionEditor(caption.closest<HTMLElement>('[data-daily-photo]')));
    });

    document.querySelectorAll<HTMLFormElement>('[data-caption-form]').forEach(form => {
      form.addEventListener('submit', async event => {
        event.preventDefault();
        const textarea = form.querySelector<HTMLTextAreaElement>('textarea');
        const message = form.querySelector<HTMLElement>('[data-caption-message]');
        const submit = form.querySelector<HTMLButtonElement>('button[type="submit"]');
        const caption = textarea?.value || '';
        if (submit) submit.disabled = true;
        if (message) message.hidden = true;
        try {
          const response = await fetch(`/api/photos/${form.dataset.photoId}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ caption }),
          });
          if (!response.ok) throw new Error(await response.text());
          const data = await response.json();
          const captionElement = form.closest<HTMLElement>('[data-daily-photo]')?.querySelector<HTMLElement>('[data-photo-caption]');
          if (captionElement) {
            captionElement.textContent = String(data.caption || '');
            captionElement.hidden = !data.caption;
          }
          if (textarea) textarea.value = String(data.caption || '');
          form.hidden = true;
        } catch (error) {
          if (message) {
            message.textContent = error instanceof Error ? error.message : 'Não foi possível salvar a legenda.';
            message.hidden = false;
          }
        } finally {
          if (submit) submit.disabled = false;
        }
      });
    });

    const postDialog = document.querySelector<HTMLElement>('[data-post-dialog]');
    const postForm = document.querySelector<HTMLFormElement>('[data-photo-form]');
    const input = document.querySelector<HTMLInputElement>('[data-photo-input]');
    const preview = document.querySelector<HTMLImageElement>('[data-photo-preview]');
    const label = document.querySelector<HTMLElement>('[data-photo-label]');
    const progress = document.querySelector<HTMLElement>('[data-upload-progress]');
    const status = document.querySelector<HTMLElement>('[data-upload-status]');
    const percent = document.querySelector<HTMLElement>('[data-upload-percent]');
    const fill = document.querySelector<HTMLElement>('[data-upload-fill]');
    const publishButton = document.querySelector<HTMLButtonElement>('[data-publish-button]');
    const postMessage = document.querySelector<HTMLElement>('[data-post-message]');
    let previewUrl = '';
    let uploadToken = '';
    let uploadPromise: Promise<string> | null = null;
    let activeUpload: XMLHttpRequest | null = null;
    let previewReady = false;
    let isPublishing = false;
    const updatePublishAvailability = () => {
      if (publishButton) publishButton.disabled = isPublishing || !(uploadToken && previewReady);
    };

    const showPostMessage = (message = '', type = 'error') => {
      if (!postMessage) return;
      postMessage.textContent = message;
      postMessage.dataset.type = type;
      postMessage.hidden = !message;
    };

    const responseError = async (response: Response) => {
      const contentType = response.headers.get('content-type') || '';
      if (contentType.includes('application/json')) {
        const data = await response.json().catch(() => ({}));
        return String(data.error || 'Não foi possível concluir a operação.');
      }
      return (await response.text()) || 'Não foi possível concluir a operação.';
    };

    const setPostDialogOpen = (open: boolean) => {
      if (!postDialog || (!open && isPublishing)) return;
      postDialog.hidden = !open;
      postDialog.classList.remove('is-closing');
      document.documentElement.classList.toggle('dialog-open', open);
    };

    const preloadPublishedPhoto = async (photoId: number) => {
      if (!Number.isInteger(photoId) || photoId <= 0) throw new Error('A foto foi publicada, mas não foi possível confirmar seu carregamento.');
      const image = new Image();
      image.decoding = 'async';
      image.src = `/api/photos/${photoId}?published=${Date.now()}`;
      await new Promise<void>((resolve, reject) => {
        image.onload = () => resolve();
        image.onerror = () => reject(new Error('A foto foi publicada, mas ainda não carregou. Tente novamente em instantes.'));
      });
      if (typeof image.decode === 'function') await image.decode().catch(() => undefined);
    };

    const fadeOutPublishedDialog = async () => {
      if (!postDialog) return;
      postDialog.classList.add('is-closing');
      await new Promise(resolve => window.setTimeout(resolve, 420));
    };

    document.querySelector('[data-open-post-dialog]')?.addEventListener('click', () => setPostDialogOpen(true));
    document.querySelectorAll('[data-close-post-dialog]').forEach(element => element.addEventListener('click', () => setPostDialogOpen(false)));

    function stagePhoto(file: File): Promise<string> {
      activeUpload?.abort();
      uploadToken = '';
      showPostMessage();
      updatePublishAvailability();
      progress?.removeAttribute('hidden');
      if (status) status.textContent = 'Enviando foto…';
      if (percent) percent.textContent = '0%';
      if (fill) fill.style.width = '0%';

      uploadPromise = new Promise((resolve, reject) => {
        const xhr = new XMLHttpRequest();
        activeUpload = xhr;
        const data = new FormData();
        data.append('photo', file);
        xhr.open('POST', '/api/photos/stage');
        xhr.upload.onprogress = event => {
          if (!event.lengthComputable) return;
          const value = Math.round(event.loaded / event.total * 100);
          if (percent) percent.textContent = `${value}%`;
          if (fill) fill.style.width = `${value}%`;
        };
        xhr.upload.onload = () => { if (status) status.textContent = postForm?.dataset.processingText || 'Processando imagem…'; };
        xhr.onload = () => {
          activeUpload = null;
          if (xhr.status < 200 || xhr.status >= 300) {
            reject(new Error(xhr.responseText || 'Não foi possível enviar a imagem.'));
            return;
          }
          const data = JSON.parse(xhr.responseText);
          uploadToken = String(data.uploadToken || '');
          if (status) status.textContent = 'Imagem pronta';
          if (percent) percent.textContent = '100%';
          if (fill) fill.style.width = '100%';
          updatePublishAvailability();
          resolve(uploadToken);
        };
        xhr.onerror = () => { activeUpload = null; reject(new Error('Não foi possível enviar a imagem.')); };
        xhr.onabort = () => reject(new Error('Envio substituído.'));
        xhr.send(data);
      });

      uploadPromise.catch(error => {
        if (activeUpload) return;
        if (status) status.textContent = 'Falha no envio';
        updatePublishAvailability();
        if (error.message !== 'Envio substituído.') showPostMessage(error.message);
      });
      return uploadPromise;
    }

    input?.addEventListener('change', () => {
      const file = input.files?.[0];
      previewReady = false;
      uploadToken = '';
      updatePublishAvailability();
      if (!file || !file.type.startsWith('image/') || !preview) {
        showPostMessage('Escolha um arquivo de imagem válido.');
        return;
      }
      if (previewUrl) URL.revokeObjectURL(previewUrl);
      previewUrl = URL.createObjectURL(file);
      preview.onload = () => {
        previewReady = true;
        updatePublishAvailability();
      };
      preview.onerror = () => {
        previewReady = false;
        uploadToken = '';
        activeUpload?.abort();
        updatePublishAvailability();
        showPostMessage('Não foi possível carregar a imagem selecionada.');
      };
      preview.src = previewUrl;
      preview.hidden = false;
      if (label) label.hidden = true;
      stagePhoto(file);
    });

    postForm?.addEventListener('submit', async event => {
      event.preventDefault();
      if (publishButton) publishButton.disabled = true;
      try {
        if (!previewReady) throw new Error('Aguarde a imagem terminar de carregar.');
        const token = uploadToken || await uploadPromise;
        if (!token || !previewReady) throw new Error('Aguarde a imagem terminar de carregar.');
        if (status) status.textContent = 'Publicando…';
        const caption = String(new FormData(postForm).get('caption') || '');
        isPublishing = true;
        postDialog?.classList.add('is-finalizing');
        postDialog?.setAttribute('aria-busy', 'true');
        if (status) status.textContent = 'Publicando sua foto…';
        if (percent) percent.textContent = '100%';
        if (fill) fill.style.width = '100%';

        const response = await fetch('/api/photos/today', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ uploadToken: token, caption }),
        });
        if (!response.ok) {
          if (response.status === 429) {
            const data = await response.json().catch(() => ({})) as { error?: string };
            throw new Error(String(data.error || 'Limite temporário de publicação atingido.'));
          }
          throw new Error(await responseError(response));
        }
        const result = await response.json() as { photoId?: number };

        if (status) status.textContent = 'Carregando no perfil…';
        postDialog?.classList.add('is-loading-published-photo');
        await preloadPublishedPhoto(Number(result.photoId || 0));

        if (status) status.textContent = 'Foto publicada';
        postDialog?.classList.remove('is-loading-published-photo');
        postDialog?.classList.add('is-published');
        await new Promise(resolve => window.setTimeout(resolve, 260));
        await fadeOutPublishedDialog();
        location.reload();
      } catch (error) {
        isPublishing = false;
        postDialog?.classList.remove('is-finalizing', 'is-loading-published-photo', 'is-published', 'is-closing');
        postDialog?.removeAttribute('aria-busy');
        if (status) status.textContent = 'Imagem pronta';
        showPostMessage(error instanceof Error ? error.message : 'Não foi possível publicar.');
        updatePublishAvailability();
      }
    });
    const formatCommentDate = (value: string) => new Intl.DateTimeFormat(document.documentElement.lang || 'pt-BR', { day: '2-digit', month: 'short', year: 'numeric' }).format(new Date(value));
    const iconAttrs = `width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"`;
    const deleteButtonHtml = `<button class="comment-delete-trigger" type="button" data-comment-delete-trigger aria-label="Excluir mensagem" title="Excluir mensagem"><svg ${iconAttrs}><path d="M4 7h16M9 7V4h6v3m-8 0 1 13h8l1-13M10 11v5m4-5v5" /></svg></button>`;
    const cancelIcon = `<svg ${iconAttrs}><path d="m7 7 10 10M17 7 7 17" /></svg>`;
    const confirmIcon = `<svg ${iconAttrs}><path d="m5 12 4 4L19 6" /></svg>`;
    const undoIcon = `<svg ${iconAttrs}><path d="M9 7 4 12l5 5M5 12h8a6 6 0 1 1 0 12" /></svg>`;


    const showCommentActionError = (item: HTMLElement, message: string) => {
      const area = item.querySelector<HTMLElement>('[data-comment-delete-area]');
      if (!area) return;
      area.innerHTML = '';
      const error = document.createElement('span');
      error.className = 'comment-delete-error';
      error.textContent = message;
      area.append(error);
      window.setTimeout(() => {
        area.innerHTML = deleteButtonHtml;
      }, 2500);
    };

    document.addEventListener('click', async event => {
      const target = event.target as HTMLElement;
      const item = target.closest<HTMLElement>('[data-comment-item]');
      if (!item) return;
      const area = item.querySelector<HTMLElement>('[data-comment-delete-area]');
      const id = Number(item.dataset.commentId);
      if (!area || !id) return;

      if (target.closest('[data-comment-delete-trigger]')) {
        area.innerHTML = `
          <span class="comment-delete-confirm">Excluir?</span>
          <button class="comment-action-button is-confirm" type="button" data-comment-delete-confirm aria-label="Confirmar exclusão" title="Confirmar">${confirmIcon}</button>
          <button class="comment-action-button" type="button" data-comment-delete-cancel aria-label="Cancelar exclusão" title="Cancelar">${cancelIcon}</button>
        `;
        return;
      }

      if (target.closest('[data-comment-delete-cancel]')) {
        area.innerHTML = deleteButtonHtml;
        return;
      }

      if (target.closest('[data-comment-delete-confirm]')) {
        const response = await fetch(`/api/comments/${id}`, { method: 'DELETE' });
        const data = await response.json().catch(() => ({}));
        if (!response.ok) {
          showCommentActionError(item, String(data.error || 'Não foi possível excluir.'));
          return;
        }

        item.classList.add('is-comment-deleted');
        area.innerHTML = `
          <span class="comment-deleted-label">Mensagem excluída</span>
          <button class="comment-undo-button" type="button" data-comment-undo>${undoIcon}<span>Desfazer</span></button>
        `;

        const commentList = item.closest<HTMLElement>('[data-comment-list]');
        const commentPanel = item.closest<HTMLElement>('[data-comments-panel]');
        const removeTimer = window.setTimeout(() => {
          item.remove();
          if (commentList && !commentList.querySelector('[data-comment-item]')) {
            commentList.hidden = true;
            const empty = commentPanel?.querySelector<HTMLElement>('[data-comment-empty]');
            if (empty) empty.hidden = false;
          }
        }, 5000);
        item.dataset.removeTimer = String(removeTimer);
        return;
      }

      if (target.closest('[data-comment-undo]')) {
        const timer = Number(item.dataset.removeTimer);
        if (timer) window.clearTimeout(timer);
        const response = await fetch(`/api/comments/${id}`, { method: 'PATCH' });
        const data = await response.json().catch(() => ({}));
        if (!response.ok) {
          showCommentActionError(item, String(data.error || 'Não foi possível desfazer.'));
          return;
        }
        item.classList.remove('is-comment-deleted');
        delete item.dataset.removeTimer;
        area.innerHTML = deleteButtonHtml;
      }
    });
    document.addEventListener('submit', async event => {
        const form = (event.target as HTMLElement).closest<HTMLFormElement>('[data-comment-form]');
        if (!form) return;
        event.preventDefault();
        const field = form.elements.namedItem('message') as HTMLInputElement;
        const button = form.querySelector<HTMLButtonElement>('button[type="submit"]');
        const privateField = form.elements.namedItem('private') as HTMLInputElement | null;
        const panel = form.closest<HTMLElement>('[data-comments-panel]');
        const list = panel?.querySelector<HTMLElement>('[data-comment-list]');
        const empty = panel?.querySelector<HTMLElement>('[data-comment-empty]');
        const messageBox = panel?.querySelector<HTMLElement>('[data-comment-message]');
        const message = field.value.trim();
        const isPrivate = Boolean(privateField?.checked);
        if (!message || form.dataset.sending === 'true') return;

        form.dataset.sending = 'true';
        field.disabled = true;
        if (button) button.disabled = true;
        if (messageBox) messageBox.hidden = true;

        try {
          const response = await fetch('/api/comments', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ postId: Number(form.dataset.postId), message, private: isPrivate }),
          });
          const data = await response.json().catch(() => ({}));
          if (!response.ok) throw new Error(String(data.error || 'Não foi possível enviar a mensagem.'));

          if (list && data.comment) {
            const article = document.createElement('article');
            const userLink = document.createElement('a');
            const strong = document.createElement('strong');
            const text = document.createElement('p');
            const time = document.createElement('time');
            const content = document.createElement('div');
            const deleteArea = document.createElement('div');
            const deleteButton = document.createElement('button');
            userLink.className = 'comment-user';
            userLink.href = `/perfil/${encodeURIComponent(String(data.comment.username))}`;
            strong.textContent = `@${data.comment.username}`;
            text.textContent = String(data.comment.message || message);
            time.textContent = formatCommentDate(String(data.comment.createdAt || new Date().toISOString()));
            article.className = isPrivate ? 'comment-item comment-item-private-visible' : 'comment-item';
            article.dataset.commentItem = '';
            article.dataset.commentId = String(data.comment.id || '');
            content.className = 'comment-content';
            deleteArea.className = 'comment-delete-area';
            deleteArea.dataset.commentDeleteArea = '';
            deleteButton.className = 'comment-delete-trigger';
            deleteButton.type = 'button';
            deleteButton.dataset.commentDeleteTrigger = '';
            deleteButton.setAttribute('aria-label', 'Excluir mensagem');
            deleteButton.title = 'Excluir mensagem';
            deleteButton.innerHTML = `<svg ${iconAttrs}><path d="M4 7h16M9 7V4h6v3m-8 0 1 13h8l1-13M10 11v5m4-5v5" /></svg>`;
            const meta = document.createElement('div');
            meta.className = 'comment-meta';
            userLink.append(strong);
            deleteArea.append(deleteButton);
            meta.append(deleteArea, time);
            content.append(userLink);
            if (isPrivate) {
              const badge = document.createElement('div');
              badge.className = 'private-comment-badge private-comment-badge-visible';
              badge.innerHTML = '<span aria-hidden="true">🔒</span> Mensagem privada';
              text.className = 'private-comment-message';
              content.append(badge);
            }
            content.append(text, meta);
            article.append(content);
            list.append(article);
            list.hidden = false;
          }
          if (empty) empty.hidden = true;
          field.value = '';
          if (privateField) privateField.checked = false;
          field.focus();
        } catch (error) {
          if (messageBox) {
            messageBox.textContent = error instanceof Error ? error.message : 'Não foi possível enviar a mensagem.';
            messageBox.hidden = false;
          }
        } finally {
          delete form.dataset.sending;
          field.disabled = false;
          if (button) button.disabled = false;
        }
    });
  </script>
</AppLayout>


