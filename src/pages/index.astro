---
import AppLayout from '../layouts/AppLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { requireUser } from '../lib/server/session';
import { getFeedPhotos } from '../lib/server/repositories/photos';
import { getMessages, normalizeLocale } from '../i18n';

const user = await requireUser(Astro);
const locale = normalizeLocale(Astro.cookies.get('fotolife-language')?.value);
const t = getMessages(locale);
const requestedLiveCount = Number.parseInt(Astro.url.searchParams.get('__live_count') || '20', 10);
const feedLimit = Math.min(100, Math.max(20, Number.isFinite(requestedLiveCount) ? requestedLiveCount : 20));
const photos = await getFeedPhotos(feedLimit, 0);
const updates = photos.slice(0, 10);
const formatDate = (value: string) => new Intl.DateTimeFormat(locale, {
  day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit'
}).format(new Date(value));
---
<AppLayout title={`${t.home.feedTitle} — ${t.site.title}`}>
  <main class="feed-page">
    <SiteHeader username={user.username} />

    <section class="home-feed-layout site-container site-section">
      <aside class="site-updates-panel">
        <h1>{t.home.updates}</h1>
        <div class="site-updates-list" data-live-section="home-updates" data-live-list>
          {updates.map(photo => (
            <a href={`#foto-${photo.id}`} data-live-key={`update-${photo.id}`}>
              <img src={`/api/photos/${photo.id}`} alt="" loading="lazy" />
              <span>
                <strong>@{photo.username}</strong>
                <small>{formatDate(photo.publishedAt)}</small>
              </span>
            </a>
          ))}
        </div>
      </aside>

      <section class="photo-feed-column" aria-label={t.home.feedTitle}>
        <div class="photo-feed" data-photo-feed data-live-section="home-feed" data-live-list>
          {photos.map(photo => (
            <article class="photo-post" id={`foto-${photo.id}`} data-photo-id={photo.id} data-live-key={`photo-${photo.id}`}>
              <header class="photo-post-header">
                <a href={`/perfil/${photo.username}`}><strong>@{photo.username}</strong></a>
                <time>{formatDate(photo.publishedAt)}</time>
              </header>

              <a class="photo-post-image-link" href={`/perfil/${photo.username}`} aria-label={`Ver perfil de @${photo.username}`}>
                <img class="photo-post-image" src={`/api/photos/${photo.id}`} alt={photo.caption || `@${photo.username}`} loading="lazy" />
              </a>
              {photo.caption && <p class="photo-post-caption">{photo.caption}</p>}
            </article>
          ))}
        </div>

        {feedLimit === 20 && photos.length === 20 && <button class="feed-load-more" type="button" data-load-more>Carregar mais</button>}
        {!photos.length && <p class="empty-state feed-empty">{t.home.noUpdates}</p>}
      </section>
    </section>
  </main>

  <script define:vars={{ locale }}>
    const feed = document.querySelector('[data-photo-feed]');
    const loadMoreButton = document.querySelector('[data-load-more]');
    let feedOffset = document.querySelectorAll('.photo-post').length;

    const formatDate = value => new Intl.DateTimeFormat(locale, {
      day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit'
    }).format(new Date(value));

    const escapeHtml = value => String(value).replace(/[&<>'"]/g, char => ({
      '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;'
    })[char]);

    function postHtml(photo) {
      return `<article class="photo-post" id="foto-${photo.id}" data-photo-id="${photo.id}" data-live-key="photo-${photo.id}">
        <header class="photo-post-header"><a href="/perfil/${encodeURIComponent(photo.username)}"><strong>@${escapeHtml(photo.username)}</strong></a><time>${formatDate(photo.publishedAt)}</time></header>
        <a class="photo-post-image-link" href="/perfil/${encodeURIComponent(photo.username)}" aria-label="Ver perfil de @${escapeHtml(photo.username)}"><img class="photo-post-image" src="/api/photos/${photo.id}" alt="${escapeHtml(photo.caption || `@${photo.username}`)}" loading="lazy"></a>
        ${photo.caption ? `<p class="photo-post-caption">${escapeHtml(photo.caption)}</p>` : ''}
      </article>`;
    }

    let feedLoading = false;

    function feedSkeletonHtml() {
      return `<div class="feed-skeletons" data-feed-skeletons aria-hidden="true">
        ${Array.from({ length: 2 }, () => `<article class="photo-post photo-post-skeleton">
          <div class="skeleton-line skeleton-line-user"></div>
          <div class="skeleton-media"></div>
          <div class="skeleton-copy"><span></span><span></span><span></span></div>
        </article>`).join('')}
      </div>`;
    }

    async function loadMoreFeed() {
      if (!loadMoreButton || feedLoading || loadMoreButton.hidden) return;
      feedLoading = true;
      loadMoreButton.disabled = true;
      loadMoreButton.textContent = 'Carregando…';
      feed.insertAdjacentHTML('beforeend', feedSkeletonHtml());

      try {
        const response = await fetch(`/api/feed?offset=${feedOffset}`, {
          headers: { Accept: 'application/json' },
          credentials: 'same-origin',
        });
        if (!response.ok) throw new Error(`Falha ao carregar o feed: ${response.status}`);
        const data = await response.json();
        feed.querySelector('[data-feed-skeletons]')?.remove();
        feed.insertAdjacentHTML('beforeend', data.items.map(postHtml).join(''));
        feedOffset += data.items.length;
        loadMoreButton.hidden = !data.hasMore;
      } catch (error) {
        feed.querySelector('[data-feed-skeletons]')?.remove();
        loadMoreButton.textContent = 'Tentar novamente';
        console.error(error);
        return;
      } finally {
        feedLoading = false;
        loadMoreButton.disabled = false;
        if (loadMoreButton.textContent !== 'Tentar novamente') loadMoreButton.textContent = 'Carregar mais';
      }
    }

    loadMoreButton?.addEventListener('click', loadMoreFeed);

    if (loadMoreButton && 'IntersectionObserver' in window) {
      const feedObserver = new IntersectionObserver(entries => {
        if (entries.some(entry => entry.isIntersecting)) loadMoreFeed();
      }, { rootMargin: '600px 0px', threshold: 0.01 });
      feedObserver.observe(loadMoreButton);
    }
  </script>
</AppLayout>
