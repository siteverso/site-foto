---
import AppLayout from '../layouts/AppLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { requireUser } from '../lib/server/session';
import { getFeedPhotos } from '../lib/server/repositories/photos';
import { getMessages, normalizeLocale } from '../i18n';

const user = await requireUser(Astro);
const locale = normalizeLocale(Astro.cookies.get('fotolife-language')?.value);
const t = getMessages(locale);
const photos = await getFeedPhotos(30);
const formatDate = (value: string) => new Intl.DateTimeFormat(locale, {
  day: '2-digit', month: 'short', year: 'numeric'
}).format(new Date(value));
---
<AppLayout title={`${t.home.feedTitle} — ${t.site.title}`}>
  <main class="feed-page">
    <SiteHeader username={user.username} />

    <section class="feed-shell site-container site-section">

      {photos.length ? (
        <div class="feed-grid">
          {photos.map(photo => (
            <article class="feed-card">
              <a class="feed-card-image" href={`/perfil/${photo.username}`}>
                <img src={`/api/photos/${photo.id}`} alt={photo.caption || `@${photo.username}`} loading="lazy" />
              </a>
              <div class="feed-card-body">
                <a href={`/perfil/${photo.username}`}><strong>@{photo.username}</strong></a>
                <time>{formatDate(photo.publishedAt)}</time>
                {photo.caption && <p>{photo.caption}</p>}
              </div>
            </article>
          ))}
        </div>
      ) : <p class="empty-state feed-empty">{t.home.noUpdates}</p>}
    </section>
  </main>

</AppLayout>
