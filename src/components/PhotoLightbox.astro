---
type AdjacentIds = { previousId: number | null; nextId: number | null; firstId: number | null; lastId: number | null };
type Props = {
  photoId: number;
  username: string;
  caption: string;
  alt: string;
  globalNavigation: AdjacentIds;
  profileNavigation: AdjacentIds;
  closeLabel: string;
  fullscreenLabel: string;
  previousLabel: string;
  nextLabel: string;
  profileModeLabel: string;
  globalModeLabel: string;
  slideshowLabel: string;
  pauseLabel: string;
  intervalLabel: string;
  loopLabel: string;
};

const {
  photoId, username, caption, alt,
  globalNavigation, profileNavigation,
  closeLabel, fullscreenLabel, previousLabel, nextLabel,
  profileModeLabel, globalModeLabel, slideshowLabel, pauseLabel,
  intervalLabel, loopLabel,
} = Astro.props;
---

<dialog
  class="photo-lightbox"
  data-photo-lightbox
  data-photo-id={photoId}
  data-global-previous={globalNavigation.previousId ?? ''}
  data-global-next={globalNavigation.nextId ?? ''}
  data-global-first={globalNavigation.firstId ?? ''}
  data-global-last={globalNavigation.lastId ?? ''}
  data-profile-previous={profileNavigation.previousId ?? ''}
  data-profile-next={profileNavigation.nextId ?? ''}
  data-profile-first={profileNavigation.firstId ?? ''}
  data-profile-last={profileNavigation.lastId ?? ''}
  data-slideshow-label={slideshowLabel}
  data-pause-label={pauseLabel}
  aria-label={alt}
>
  <div class="photo-lightbox-shell" data-photo-lightbox-shell>
    <figure class="photo-lightbox-stage" data-photo-stage>
      <img class="photo-lightbox-image" src={`/api/photos/${photoId}`} alt={alt} data-photo-lightbox-image draggable="false" />
      <figcaption class="photo-lightbox-caption" hidden={!caption}>
        <span>{caption}</span>
      </figcaption>
      <a
        class="photo-lightbox-watermark"
        href={`/perfil/${encodeURIComponent(username)}`}
        aria-label={`${profileModeLabel}: @${username}`}
        title={`@${username}`}
      >@{username}</a>
    </figure>

    <div class="photo-lightbox-toolbar">
      <div class="photo-lightbox-segmented" role="group" aria-label={profileModeLabel}>
        <button type="button" data-navigation-mode="profile">{profileModeLabel}</button>
        <button type="button" data-navigation-mode="global">{globalModeLabel}</button>
      </div>
      <button type="button" class="photo-lightbox-button" data-photo-fullscreen aria-label={fullscreenLabel} title={fullscreenLabel}>
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 9V4h5M15 4h5v5M20 15v5h-5M9 20H4v-5"/></svg>
      </button>
      <button type="button" class="photo-lightbox-button" data-photo-lightbox-close aria-label={closeLabel} title={closeLabel}>
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m6 6 12 12M18 6 6 18"/></svg>
      </button>
    </div>

    <a class="photo-lightbox-nav photo-lightbox-nav--previous" href="#" aria-label={previousLabel} title={previousLabel} data-photo-previous>
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
    </a>
    <a class="photo-lightbox-nav photo-lightbox-nav--next" href="#" aria-label={nextLabel} title={nextLabel} data-photo-next>
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
    </a>

    <div class="photo-lightbox-slideshow" aria-label={slideshowLabel}>
      <button type="button" class="photo-lightbox-play" data-slideshow-toggle>
        <span aria-hidden="true" data-slideshow-icon>▶</span>
        <span data-slideshow-text>{slideshowLabel}</span>
      </button>
      <label>{intervalLabel}
        <select data-slideshow-interval>
          <option value="2000">2s</option><option value="3000">3s</option>
          <option value="5000" selected>5s</option><option value="8000">8s</option><option value="10000">10s</option>
        </select>
      </label>
      <label class="photo-lightbox-checkbox">
        <input type="checkbox" data-slideshow-loop checked />
        <span>{loopLabel}</span>
      </label>
    </div>
  </div>
</dialog>
