---
import LanguageSwitch from './LanguageSwitch.astro';
import '../styles/components/site-header.css';
import { getMessages, normalizeLocale } from '../i18n';
import { getAvatarSources } from '../lib/avatar';

interface Props {
  username?: string;
  userId?: number | string;
  avatarUrl?: string;
}

const { username, userId, avatarUrl = '' } = Astro.props;
const avatarSources = getAvatarSources(userId, avatarUrl);
const resolvedAvatarUrl = avatarSources[0] || '';
const locale = normalizeLocale(Astro.cookies.get('fotolife-language')?.value);
const t = getMessages(locale);
---
<header class="site-header">
  <div class="site-header-inner site-container">
    <a class="wordmark dark" href="/" aria-label={t.site.title}><span>foto</span>life</a>

    <nav class="site-header-actions" aria-label={t.common.navigation}>
      {username ? (
        <>
          <a class="site-user-link" href={`/perfil/${username}`} data-user-profile-link>
            <span class="site-user-avatar" aria-hidden="true">
              {resolvedAvatarUrl ? (
                <>
                  <img src={resolvedAvatarUrl} alt="" width="40" height="40" data-site-user-avatar-image data-avatar-sources={JSON.stringify(avatarSources)} />
                  <span class="site-user-avatar-placeholder" data-site-user-avatar-placeholder hidden></span>
                </>
              ) : <span class="site-user-avatar-placeholder"></span>}
            </span>
            <strong data-user-name>@{username}</strong>
          </a>
          <LanguageSwitch locale={locale} />
          <button class="site-theme-toggle" type="button" data-theme-toggle aria-label={t.common.changeTheme} title={t.common.changeTheme}><span aria-hidden="true">☀</span></button>
          <button class="flog-logout" type="button" data-logout>{t.home.logout}</button>
        </>
      ) : (
        <>
          <LanguageSwitch locale={locale} />
          <button class="site-theme-toggle" type="button" data-theme-toggle aria-label={t.common.changeTheme} title={t.common.changeTheme}><span aria-hidden="true">☀</span></button>
          <a class="site-account-link" href="/login">{t.common.signIn}</a>
        </>
      )}
    </nav>
  </div>
</header>

<script>
  document.querySelectorAll('[data-site-user-avatar-image]').forEach(image => {
    if (!(image instanceof HTMLImageElement)) return;

    let sources = [];
    try {
      const parsed = JSON.parse(image.dataset.avatarSources || '[]');
      if (Array.isArray(parsed)) sources = parsed.filter(source => typeof source === 'string' && source.trim());
    } catch {
      sources = image.currentSrc || image.src ? [image.currentSrc || image.src] : [];
    }

    let sourceIndex = Math.max(0, sources.findIndex(source => image.getAttribute('src') === source));
    image.addEventListener('load', () => {
      image.hidden = false;
      const placeholder = image.parentElement?.querySelector('[data-site-user-avatar-placeholder]');
      if (placeholder instanceof HTMLElement) placeholder.hidden = true;
    });
    image.addEventListener('error', () => {
      sourceIndex += 1;
      const nextSource = sources[sourceIndex];
      if (nextSource) {
        image.src = nextSource;
        return;
      }

      image.hidden = true;
      const placeholder = image.parentElement?.querySelector('[data-site-user-avatar-placeholder]');
      if (placeholder instanceof HTMLElement) placeholder.hidden = false;
    });
  });

  const themeLabels = JSON.parse(document.documentElement.dataset.themeLabels || '{}');
  const FOTO_THEMES = [
    { code: 'light', name: themeLabels.light || 'Claro', icon: '☀', scheme: 'light' },
    { code: 'light-warm', name: themeLabels.lightWarm || 'Claro quente', icon: '◒', scheme: 'light' },
    { code: 'dark', name: themeLabels.dark || 'Escuro', icon: '☾', scheme: 'dark' },
    { code: 'dark-blue', name: themeLabels.darkBlue || 'Escuro azulado', icon: '◐', scheme: 'dark' },
  ];
  const currentNextLabel = themeLabels.currentNext || 'Tema {current}. Ativar {next}';
  const nextLabel = themeLabels.next || '{current} · próximo: {next}';

  const themeButton = document.querySelector('[data-theme-toggle]');

  function currentThemeIndex() {
    const current = document.documentElement.dataset.theme || 'light';
    const index = FOTO_THEMES.findIndex(theme => theme.code === current);
    return index >= 0 ? index : 0;
  }

  function refreshThemeButton() {
    if (!(themeButton instanceof HTMLButtonElement)) return;
    const currentIndex = currentThemeIndex();
    const current = FOTO_THEMES[currentIndex];
    const next = FOTO_THEMES[(currentIndex + 1) % FOTO_THEMES.length];
    const icon = themeButton.querySelector('span');
    if (icon) icon.textContent = current.icon;
    themeButton.dataset.currentTheme = current.code;
    themeButton.setAttribute('aria-label', currentNextLabel.replace('{current}', current.name).replace('{next}', next.name));
    themeButton.title = nextLabel.replace('{current}', current.name).replace('{next}', next.name);
  }

  refreshThemeButton();
  themeButton?.addEventListener('click', () => {
    const next = FOTO_THEMES[(currentThemeIndex() + 1) % FOTO_THEMES.length];
    document.documentElement.dataset.theme = next.code;
    document.cookie = `fotolife-theme=${next.code}; path=/; max-age=31536000; SameSite=Lax`;
    document.querySelector('meta[name="color-scheme"]')?.setAttribute('content', next.scheme);
    refreshThemeButton();
  });

  document.querySelector('[data-logout]')?.addEventListener('click', async () => {
    await fetch('/api/auth/logout', { method: 'POST' });
    location.href = '/login';
  });
</script>
