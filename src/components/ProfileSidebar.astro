---
import '../styles/components/profile-account-card.css';
import '../styles/components/profile-avatar.css';
import '../styles/processes/avatar-editing.css';
import { getMessages, normalizeLocale } from '../i18n';
const locale = normalizeLocale(Astro.cookies.get('fotolife-language')?.value);
const t = getMessages(locale);
const {
  profile,
  editableAvatar = false,
  isOwner = false,
  alreadyFriend = false,
  labels = {},
  showStats = false,
  blockState = { messages: false, profileAccess: false, hideMe: false, hideThem: false },
} = Astro.props;

const username = profile?.username || 'usuario';
const initials = username.slice(0, 2).toUpperCase() || 'FL';
const avatarUrl = profile?.avatarUrl || '';
const hasCustomAvatar = Boolean(profile?.hasCustomAvatar ?? avatarUrl);
---
<div class="profile-sidebar-stack">
  <section class="profile-summary-card profile-sidebar-card">
    <div class="user-profile-intro user-profile-intro-sidebar">
      {editableAvatar ? (
        <button class="profile-avatar-button profile-avatar-edit-button" type="button" data-profile-avatar data-avatar-trigger data-avatar-container data-avatar-user-id={profile?.id} aria-label={t.profile.changePhoto} title={t.profile.changePhoto}>
          {avatarUrl && <img src={avatarUrl} alt={`@${username}`} data-avatar-image data-avatar-user-id={profile?.id} />}
          <span data-profile-avatar-fallback data-avatar-fallback hidden={Boolean(avatarUrl)}>{initials}</span>
        </button>
      ) : (
        <button class="profile-avatar-button" type="button" data-open-avatar-dialog data-avatar-container data-avatar-user-id={profile?.id} aria-label={`${t.profile.enlargePhoto} @${username}`}>
          {avatarUrl ? <><img src={avatarUrl} alt={`@${username}`} data-avatar-image data-avatar-user-id={profile?.id} /><span data-avatar-fallback hidden>{initials}</span></> : <span data-avatar-fallback>{initials}</span>}
        </button>
      )}
      <div>
        <h1 data-profile-username>@{username}</h1>
        {profile?.email && <span class="handle" data-profile-email>{profile.email}</span>}
        {profile?.bio && <p data-profile-bio>{profile.bio}</p>}
      </div>
    </div>

    {editableAvatar && (
      <form class="account-avatar-form" data-avatar-form data-avatar-user-id={profile?.id}>
        <div class="account-avatar-actions">
          <label class="profile-account-link" for="profileAvatar">{t.profile.changePhoto}</label>
          <button
              class="account-avatar-remove"
              type="button"
              data-avatar-remove
              aria-label={t.profile.removePhoto}
              title={t.profile.removePhoto}
              hidden={!hasCustomAvatar}
            >
              <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path d="M9 3h6l1 2h4v2H4V5h4l1-2Zm-2 6h10l-.7 11H7.7L7 9Zm3 2v7m4-7v7" />
              </svg>
            </button>
        </div>
        <input id="profileAvatar" name="avatar" type="file" accept="image/jpeg,image/png,image/webp" hidden data-avatar-input />
        <small>{t.profile.photoHelp}</small>
        <p class="form-message" data-form-message hidden></p>
      </form>
    )}

    {showStats && (
      <div class="profile-stats profile-sidebar-stats">
        <div><strong data-profile-posts>{profile?.photoCount || 0}</strong><span>{labels.photos || t.profile.photos}</span></div>
        <div><strong data-profile-positive>{profile?.messageCount || 0}</strong><span>{labels.messages || t.profile.messages}</span></div>
        <div><strong data-profile-observed>{profile?.observedCount || 0}</strong><span>{labels.observed || t.profile.observed}</span></div>
        <div><strong data-profile-shares>{profile?.observerCount || 0}</strong><span>{labels.observers || t.profile.observers}</span></div>
      </div>
    )}

    {!isOwner && !editableAvatar && (
      <div class="profile-relationship-actions" data-profile-actions data-user-id={profile?.id}>
        <div class="profile-relationship-toolbar">
          <div class="profile-block-status" data-profile-block-status aria-label="Restrições ativas">
            {[
              ['messages', blockState.messages, '✉', 'Mensagens bloqueadas'],
              ['profile_access', blockState.profileAccess, '⊘', 'Acesso ao seu perfil bloqueado'],
              ['hide_me', blockState.hideMe, '◌', 'Você está invisível para esta pessoa'],
              ['hide_them', blockState.hideThem, '◉', 'Esta pessoa está oculta para você'],
            ].map(([type, active, icon, title]) => (
              <span class="profile-block-status-icon" data-profile-block-indicator={type} title={title} aria-label={title} hidden={!active}>{icon}</span>
            ))}
          </div>
          <button class="profile-more-button" type="button" data-profile-actions-toggle aria-label={`Ações para @${username}`} aria-expanded="false">•••</button>
        </div>
        <div class="profile-actions-menu" data-profile-actions-menu hidden>
          {[
            { type: 'messages', active: blockState.messages, icon: '✉', on: 'Permitir mensagens', off: 'Bloquear mensagens', help: 'Impede apenas a troca de mensagens privadas entre vocês.' },
            { type: 'profile_access', active: blockState.profileAccess, icon: '⊘', on: 'Liberar acesso ao meu perfil', off: 'Impedir acesso ao meu perfil', help: 'Esta pessoa não poderá abrir seu perfil nem observar você.' },
            { type: 'hide_me', active: blockState.hideMe, icon: '◌', on: 'Voltar a aparecer para esta pessoa', off: 'Ficar invisível para esta pessoa', help: 'Seu perfil, fotos, comentários e atividades deixam de aparecer para ela.' },
            { type: 'hide_them', active: blockState.hideThem, icon: '◉', on: 'Voltar a ver esta pessoa', off: 'Não ver esta pessoa', help: 'O perfil, as fotos, os comentários e as atividades dela deixam de aparecer para você.' },
          ].map(action => (
            <button type="button" data-profile-block-type={action.type} data-blocked={action.active ? 'true' : 'false'}>
              <span aria-hidden="true">{action.icon}</span><span><strong>{action.active ? action.on : action.off}</strong><small>{action.help}</small></span>
            </button>
          ))}
        </div>
      </div>
    )}

    {!isOwner && !editableAvatar && (
      <button
        class:list={["friend-button", { "friend-button-remove": alreadyFriend }]}
        type="button"
        data-friend-toggle
        data-user-id={profile?.id}
        data-observing={alreadyFriend ? "true" : "false"}
        aria-label={alreadyFriend ? `${t.profile.stopObserving} @${username}` : `${t.profile.observe} @${username}`}
        title={alreadyFriend ? `${t.profile.stopObserving} @${username}` : `${t.profile.observe} @${username}`}
      >
        {alreadyFriend && <span aria-hidden="true">×</span>}
        {alreadyFriend ? (labels.alreadyFriend || t.profile.observedLabel) : (labels.addFriend || t.profile.observe)}
      </button>
    )}
  </section>

  {isOwner && !editableAvatar && (
    <div class="profile-sidebar-owner-actions">
      <a class="profile-account-link profile-sidebar-external-action" href="/conta">{t.profile.editAccount}</a>
      <a class="profile-account-link profile-sidebar-external-action" href="/perfil/mensagens-enviadas">{t.profile.sentMessages}</a>
    </div>
  )}
  {editableAvatar && <a class="profile-account-link profile-sidebar-external-action" href="/perfil">{t.profile.viewMyProfile}</a>}
</div>

{editableAvatar && <script type="module" src="/profile-avatar.js?v=20260713-1"></script>}
{!isOwner && !editableAvatar && <script type="module" src="/js/processes/profile-blocking.js?v=20260713-5"></script>}
