PUBLIC_SITE_NAME="FotoLife"
PUBLIC_SITE_DESCRIPTION="A rede mais fácil do mundo"
PUBLIC_GOOGLE_CLIENT_ID="SEU_CLIENT_ID.apps.googleusercontent.com"

# Oracle Autonomous Database
ORACLE_USER="MURMDB"
ORACLE_PASSWORD="COLOQUE_A_SENHA_AQUI"
ORACLE_CONNECT_STRING="siteverso_low"
ORACLE_WALLET_DIR="/home/daniel/.oracle/Wallet_siteverso"
ORACLE_POOL_MIN="0"
ORACLE_POOL_MAX="4"
ORACLE_POOL_INCREMENT="1"
ORACLE_QUEUE_TIMEOUT_MS="10000"

# Sessão própria do FotoLife
SESSION_COOKIE_NAME="fotolife_session"
SESSION_DAYS="30"

# Somente desenvolvimento. Em produção mantenha false até integrar e-mail.
ALLOW_LOCAL_PASSWORD_RESET="false"


# Limite de publicação de fotos
# Tipos aceitos: minute | hour | day | week | month
PHOTO_POST_LIMIT="2"
PHOTO_POST_INTERVAL_TYPE="minute"

# Limite de caracteres para legendas, comentários e textos do usuário
PUBLIC_MESSAGE_MAX_LENGTH="256"
